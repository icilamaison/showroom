# PostgreSQL
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Express
SERVER_PORT=4000
NODE_ENV=production

# JWT (배포 시 반드시 새 랜덤값으로 교체: openssl rand -base64 48)
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# 최초 관리자 계정 (npm run db:seed 실행 시 생성)
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-me

# CORS (Vercel 배포 주소)
CLIENT_ORIGIN=https://showroom-olive.vercel.app
