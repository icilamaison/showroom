# PostgreSQL connection string
# Example: postgresql://user:password@localhost:5432/play_auto
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/play_auto

# Express API server port (Next.js proxies /api/* to this port)
SERVER_PORT=4000

# JWT secret for admin authentication (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# JWT expiration (e.g. 1d, 12h, 7d)
JWT_EXPIRES_IN=1d

# Initial admin account created by `npm run db:seed`
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=change-me

# Node environment (development | production)
NODE_ENV=development
