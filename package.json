{
  "name": "play-auto",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:server\"",
    "dev:clean": "rm -rf .next && npm run dev",
    "dev:next": "next dev --turbopack",
    "dev:server": "tsx watch server/index.ts",
    "build": "next build && tsc -p tsconfig.server.json",
    "start": "concurrently \"next start\" \"node dist/server/index.js\"",
    "test": "vitest run",
    "test:server": "vitest run server",
    "test:client": "vitest run lib",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed": "tsx server/db/seed.ts",
    "db:seed:contracts": "tsx server/db/seed-contracts.ts",
    "db:seed:contracts:reset": "tsx server/db/seed-contracts.ts --reset",
    "products:sync-sizes": "tsx scripts/sync-product-sizes.ts",
    "lint": "next lint"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.1",
    "next": "^15.3.4",
    "pg": "^8.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.15.32",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.29.0",
    "eslint-config-next": "^15.3.4",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
